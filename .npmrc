# @jewelexperts/* packages resolve from the GROUP registry (cross-project within the
# jewelexperts-npm group). For a LOCAL STANDALONE install (i.e. not via the /git/npm
# pnpm workspace, which links them with no token), put your token in your USER ~/.npmrc
# — pnpm 11 will not expand ${ENV_VARS} from a committed project .npmrc:
#   //gitlab.com/api/v4/groups/jewelexperts-npm/-/packages/npm/:_authToken=<your_token>
@jewelexperts:registry=https://gitlab.com/api/v4/groups/jewelexperts-npm/-/packages/npm/

engine-strict=true

