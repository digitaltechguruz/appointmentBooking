<div
  id="ab-booking-widget-root"
  class="ab-booking-widget"
  data-ab-booking-widget="true"
  data-shop="{{ shop.permanent_domain }}"
  data-locale="{{ request.locale.iso_code }}"
  data-api-base="/apps/booking"
  style="min-height: 420px; width: 100%;"
></div>

<link rel="stylesheet" href="/apps/booking/static/booking-widget.css?v={{ 'now' | date: '%s' }}">
<script src="/apps/booking/static/booking-widget.js?v={{ 'now' | date: '%s' }}" defer></script>

{% schema %}
{
  "name": "Appointment Booking",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Add this block once per page. Do not also enable Appointment Booking Embed in App embeds, or the widget will appear twice."
    }
  ]
}
{% endschema %}
